# This is Git's per-user configuration file.
# to reset author after changing here: git commit --amend --reset-author
[core]
    excludesfile = ~/.gitignore_global
    hooksPath = ~/git/hooks
[user]
    name = my name
    email = <email>
    signingKey = my key
[push]
	default = simple
[commit]
    gpgSign = true
[tag]
    gpgSign = true
